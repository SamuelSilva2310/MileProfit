# Copy this to .env and fill in the values
# Generate SECRET_KEY with: openssl rand -hex 32

SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Path inside the container — matches the volume mount in docker-compose.yml
DATABASE_URL=sqlite+aiosqlite:////data/mileprofit.db

# Your production domain (no trailing slash)
CORS_ORIGINS=["https://yourdomain.com"]
